# =====================
# AgSafe environment vars
# =====================

# Weather provider
OPENWEATHERMAP_API_KEY=

# SMS provider selection: "twilio" (default) or "africastalking".
# All providers with credentials are tried as fallbacks in order.
SMS_PROVIDER=twilio

# Twilio (primary)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1234567890

# Africa's Talking (fallback). Use "sandbox" username for testing.
AT_USERNAME=
AT_API_KEY=
AT_FROM=

# Cron webhook shared secret (any random string; used by pg_cron)
CRON_WEBHOOK_SECRET=

# Supabase (auto-provisioned by Lovable Cloud)
# SUPABASE_URL=
# SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# VITE_SUPABASE_URL=
# VITE_SUPABASE_PUBLISHABLE_KEY=
